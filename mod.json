{
  "geode": "5.5.3",
  "gd": {
    "win": "2.2081",
    "mac": "2.2081"
  },
  "version": "v1.1.2",
  "id": "iswilljr.enter-search",
  "name": "Enter Search",
  "developer": "iswilljr",
  "tags": ["content", "customization", "interface", "utility"],
  "description": "Search levels on enter in the search page",
  "links": {
    "source": "https://github.com/iswilljr/enter-search-gd"
  },
  "issues": {
    "info": "If you find any bugs or have any suggestions, create an issue on github",
    "url": "https://github.com/iswilljr/enter-search-gd/issues"
  },
  "settings": {
    "enterSearch": {
      "type": "keybind",
      "name": "Enter Search",
      "description": "Search when you press enter in the level search page",
      "default": "Enter",
      "category": "universal",
      "allow-in-text-inputs": true
    }
  },
  "dependencies": {
    "geode.node-ids": {
      "version": ">=1.23.0",
      "required": true
    }
  }
}
